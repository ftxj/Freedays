{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "route-overrides.schema.json",
  "title": "西藏边境线地图剪辑指令",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "lonlat": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "minItems": 2,
      "maxItems": 2
    },
    "timeRange": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "storyEvent": {
      "type": "object",
      "required": ["id", "presentation", "title"],
      "properties": {
        "id": { "type": "string" },
        "presentation": { "enum": ["title", "media"] },
        "time": { "type": "string" },
        "lonlat": { "$ref": "#/$defs/lonlat" },
        "lead": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "video": { "type": "string" },
        "poster": { "type": "string" },
        "image": { "type": "string" },
        "image_alt": { "type": "string" },
        "duration_ms": { "type": "number", "minimum": 1500 },
        "autoplay": { "type": "boolean" },
        "priority": { "enum": ["chapter", "memory"] },
        "pause": { "type": "boolean" }
      },
      "anyOf": [{ "required": ["time"] }, { "required": ["lonlat"] }]
    },
    "mediaClip": {
      "type": "object",
      "properties": {
        "video": { "type": "string" },
        "poster": { "type": "string" },
        "image": { "type": "string" },
        "alt": { "type": "string" },
        "title": { "type": "string" },
        "label": { "type": "string" }
      },
      "anyOf": [{ "required": ["video"] }, { "required": ["image"] }]
    },
    "cameraDirective": {
      "allOf": [
        { "$ref": "#/$defs/timeRange" },
        {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "enum": ["fixed_region", "soft_follow", "follow"] },
            "center": { "$ref": "#/$defs/lonlat" },
            "look_at": { "$ref": "#/$defs/lonlat" },
            "zoom": { "type": "number" },
            "max_zoom": { "type": "number" },
            "pitch": { "type": "number" },
            "bearing": { "type": "number" },
            "padding": { "type": "number" },
            "follow_factor": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "follow_center": { "type": "boolean" },
            "playback_factor": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            }
          }
        }
      ]
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "notes": { "type": "string" },
    "mode_ranges": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/timeRange" },
          {
            "properties": {
              "mode": { "enum": ["walk", "drive_slow", "drive_fast"] },
              "label": { "type": "string" }
            },
            "required": ["mode"]
          }
        ]
      }
    },
    "geometry_edits": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/timeRange" },
          {
            "properties": {
              "via": {
                "type": "array",
                "items": { "$ref": "#/$defs/lonlat" }
              },
              "path_id": { "type": "string" },
              "via_source": {
                "enum": ["editorial_anchor", "navigation:osm", "navigation:osrm"]
              },
              "mode": { "enum": ["walk", "drive_slow", "drive_fast"] },
              "max_step_m": { "type": "number", "exclusiveMinimum": 0 },
              "authoritative_path_start": { "type": "boolean" },
              "authoritative_path_end": { "type": "boolean" }
            }
          }
        ]
      }
    },
    "road_corridors": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/timeRange" },
          {
            "properties": {
              "cache": { "type": "string" },
              "force_local": { "type": "boolean" },
              "max_snap_m": { "type": "number" },
              "max_route_m": { "type": "number" },
              "max_route_ratio": { "type": "number" }
            }
          }
        ]
      }
    },
    "camera_ranges": {
      "type": "array",
      "description": "旧版固定区域镜头，继续兼容",
      "items": { "$ref": "#/$defs/timeRange" }
    },
    "camera_directives": {
      "type": "array",
      "items": { "$ref": "#/$defs/cameraDirective" }
    },
    "tunnel_ranges": {
      "type": "array",
      "description": "OSM tunnel=yes 或人工确认的隧道时间区间",
      "items": { "$ref": "#/$defs/timeRange" }
    },
    "preview_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "start"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "start": { "type": "string", "format": "date-time" },
          "autoplay": { "type": "boolean" }
        }
      }
    },
    "route_connections": {
      "type": "array",
      "description": "只绘制、不参与播放和时间插值的跨日接驳线",
      "items": {
        "type": "object",
        "required": ["id", "path_id"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "path_id": { "type": "string" },
          "style": { "type": "string" }
        }
      }
    },
    "story_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/storyEvent" }
    },
    "title_cards": {
      "type": "array",
      "description": "旧版标题事件，继续兼容",
      "items": { "type": "object" }
    },
    "supply_events": {
      "type": "array",
      "description": "旧版物资事件，继续兼容",
      "items": { "type": "object" }
    },
    "media_events": {
      "type": "array",
      "description": "地点媒体事件；单素材兼容 video/poster，多素材使用 clips",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "anyOf": [
          { "required": ["lonlat"] },
          { "required": ["time"] }
        ],
        "properties": {
          "id": { "type": "string" },
          "lonlat": { "$ref": "#/$defs/lonlat" },
          "time": { "type": "string", "format": "date-time" },
          "kicker": { "type": "string" },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "video": { "type": "string" },
          "poster": { "type": "string" },
          "image": { "type": "string" },
          "image_alt": { "type": "string" },
          "media_layout": { "enum": ["portrait", "landscape"] },
          "duration_ms": { "type": "number", "minimum": 1500 },
          "autoplay": { "type": "boolean" },
          "clips": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/mediaClip" }
          },
          "priority": { "enum": ["chapter", "memory"] },
          "pause": { "type": "boolean" }
        }
      }
    }
  }
}
